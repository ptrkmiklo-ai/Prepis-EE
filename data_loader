import pandas as pd
import os

def load_adresar():
    csv_path = "/data/in/files/adresar.csv"  # odporúčané pre Keboola Data App
    if not os.path.exists(csv_path):
        raise FileNotFoundError(f"CSV neexistuje: {csv_path}")
    return pd.read_csv(csv_path)

def get_people_list():
    df = load_adresar()
    df = df.fillna("")
    return {row["NAME"]: row.to_dict() for _, row in df.iterrows()}
